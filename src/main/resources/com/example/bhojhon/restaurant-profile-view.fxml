<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.bhojhon.controller.RestaurantProfileController"
           styleClass="ts-root"
           stylesheets="@styles.css">

    <!-- Decorative glass pane wrapper for the entire dashboard -->
    <StackPane maxWidth="1150" maxHeight="800"
               style="-fx-background-color: white; -fx-background-radius: 36px; -fx-padding: 0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 40, 0, 0, 20);">

        <HBox VBox.vgrow="ALWAYS" style="-fx-background-radius: 36px;">
            <!-- LEFT SIDEBAR -->
            <VBox spacing="10" minWidth="240" maxWidth="240" style="-fx-background-color: #f8fafc; -fx-background-radius: 36px 0 0 36px; -fx-border-color: transparent #e2e8f0 transparent transparent; -fx-border-width: 0 1px 0 0;">
                <padding>
                    <Insets top="35" bottom="30" left="25" right="25"/>
                </padding>
                
                <VBox spacing="5" alignment="CENTER_LEFT">
                    <VBox.margin><Insets bottom="30"/></VBox.margin>
                    <Label text="🍽️ BhojhOn" style="-fx-font-size: 22px; -fx-font-weight: 900; -fx-text-fill: #1e293b;"/>
                    <Label text="Partner Portal" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #3b82f6;"/>
                </VBox>

                <!-- Nav Items -->
                <VBox spacing="15" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="12" onMouseClicked="#handleNavigateToDashboard" style="-fx-cursor: hand; -fx-background-color: transparent; -fx-padding: 12 16; -fx-border-radius: 12px;">
                        <Label text="⊞" style="-fx-text-fill: #64748b; -fx-font-size: 16px;"/>
                        <Label text="Dashboard &amp; Menu" style="-fx-text-fill: #64748b; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #3b82f6; -fx-background-radius: 12px; -fx-padding: 12 16; -fx-effect: dropshadow(three-pass-box, rgba(59,130,246,0.3), 10, 0, 0, 4);">
                        <Label text="⚙" style="-fx-text-fill: white; -fx-font-size: 16px;"/>
                        <Label text="Profile Settings" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                    </HBox>
                    <Region VBox.vgrow="ALWAYS"/>
                    <!-- Logout -->
                    <HBox alignment="CENTER_LEFT" spacing="12" onMouseClicked="#handleBack" style="-fx-cursor: hand; -fx-background-color: transparent; -fx-padding: 12 16; -fx-border-color: #e2e8f0; -fx-border-radius: 12px; -fx-border-width: 1.5px;">
                        <Label text="⏻" style="-fx-text-fill: #ef4444; -fx-font-size: 16px;"/>
                        <Label text="Logout Provider" style="-fx-text-fill: #ef4444; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- CENTER CONTENT -->
            <VBox HBox.hgrow="ALWAYS" spacing="25">
                <padding>
                    <Insets top="35" bottom="35" left="35" right="35"/>
                </padding>

                <!-- HEADER -->
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <VBox spacing="4">
                        <Label text="Profile Settings" style="-fx-font-size: 32px; -fx-font-weight: 900; -fx-text-fill: #1e293b;"/>
                        <Label text="Update your restaurant details and credentials" style="-fx-font-size: 14px; -fx-text-fill: #64748b;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <!-- Restaurant Info -->
                    <VBox alignment="CENTER_RIGHT" spacing="2">
                        <Label fx:id="restaurantNameLabel" text="Loading..." style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <Label fx:id="stationLabel" text="Station" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
                    </VBox>
                    <HBox alignment="CENTER" style="-fx-background-color: #3b82f6; -fx-background-radius: 12px; -fx-min-width: 48px; -fx-min-height: 48px;">
                        <Label text="R" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                    </HBox>
                </HBox>

                <!-- MAIN CONTENT AREA -->
                <VBox spacing="25" alignment="CENTER" VBox.vgrow="ALWAYS">
                    <VBox spacing="15" maxWidth="500" style="-fx-background-color: #f8fafc; -fx-background-radius: 16px; -fx-padding: 30; -fx-border-color: #e2e8f0; -fx-border-radius: 16px; -fx-border-width: 1;">
                        <Label text="Edit Profile Information" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        
                        <VBox spacing="15">
                            <VBox spacing="5">
                                <Label text="Restaurant Name" styleClass="login-field-label"/>
                                <TextField fx:id="nameField" promptText="Your Restaurant Name" styleClass="login-field" style="-fx-background-color: white;"/>
                            </VBox>
                            <VBox spacing="5">
                                <Label text="Business Email" styleClass="login-field-label"/>
                                <TextField fx:id="emailField" promptText="contact@restaurant.com" styleClass="login-field" style="-fx-background-color: white;"/>
                            </VBox>
                            <VBox spacing="5">
                                <Label text="New Password (Optional)" styleClass="login-field-label"/>
                                <PasswordField fx:id="passwordField" promptText="Leave blank to keep current" styleClass="login-field" style="-fx-background-color: white;"/>
                            </VBox>

                            <Label fx:id="statusLabel" text="" styleClass="login-error-label" wrapText="true"/>

                            <HBox alignment="CENTER">
                                <VBox.margin><Insets top="10"/></VBox.margin>
                                <Button text="Save Changes" onAction="#handleSaveProfile" prefWidth="Infinity" HBox.hgrow="ALWAYS" prefHeight="45" styleClass="login-btn-primary" style="-fx-background-color: #2563eb; -fx-effect: dropshadow(three-pass-box, rgba(37,99,235,0.3), 10, 0, 0, 4); -fx-font-size: 15px;"/>
                            </HBox>
                        </VBox>
                    </VBox>
                </VBox>

            </VBox>
        </HBox>
    </StackPane>
</StackPane>
