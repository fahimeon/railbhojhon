<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.bhojhon.controller.CartController"
           styleClass="ts-root"
           stylesheets="@styles.css">

    <StackPane maxWidth="900" maxHeight="750"
               style="-fx-background-color: white; -fx-background-radius: 36px; -fx-padding: 15px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 30, 0, 0, 15);">
        
        <VBox alignment="TOP_CENTER" spacing="20" styleClass="ts-card" VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>
            
            <VBox alignment="CENTER" spacing="8">
                <Label text="Shopping Cart" styleClass="fm-page-title"/>
                <Label text="Review your order before checkout" styleClass="fm-page-subtitle"/>
            </VBox>

            <!-- Table Container -->
            <VBox spacing="10" VBox.vgrow="ALWAYS" styleClass="fm-table-card">
                <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                </padding>
                
                <Label text="Your Orders:" styleClass="ts-section-header"/>
                
                <TableView fx:id="cartTableView" VBox.vgrow="ALWAYS" styleClass="fm-table" style="-fx-border-color: transparent; -fx-background-color: transparent;">
                    <columns>
                        <TableColumn fx:id="itemNameColumn" text="Item" prefWidth="300.0"/>
                        <TableColumn fx:id="priceColumn" text="Price" prefWidth="120.0" style="-fx-alignment: CENTER-RIGHT;"/>
                        <TableColumn fx:id="quantityColumn" text="Quantity" prefWidth="150.0" style="-fx-alignment: CENTER;"/>
                        <TableColumn fx:id="subtotalColumn" text="Subtotal" prefWidth="140.0" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold;"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <!-- Total Section -->
            <VBox alignment="CENTER_RIGHT" spacing="5">
                <HBox alignment="CENTER_RIGHT" spacing="15">
                    <Label text="Subtotal:" style="-fx-font-size: 18px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                    <Label fx:id="totalLabel" text="৳0" style="-fx-font-size: 28px; -fx-font-weight: 900; -fx-text-fill: #3b82f6;"/>
                </HBox>
                <Label text="* Taxes and charges calculated at checkout" style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;"/>
            </VBox>

            <!-- Action Buttons -->
            <HBox spacing="20" alignment="CENTER_RIGHT">
                <Button text="← Continue Shopping" onAction="#handleContinueShopping" styleClass="ts-btn-secondary" prefHeight="50"/>
                <Button text="Confirm Order →" onAction="#handleConfirmOrder" styleClass="ts-btn-search" prefHeight="50"/>
            </HBox>

        </VBox>
    </StackPane>

</StackPane>