<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="rootPane" xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.bhojhon.controller.RestaurantListController"
           styleClass="ts-root"
           stylesheets="@styles.css">

    <!-- Background Image -->
    <ImageView opacity="0.15" fitWidth="${rootPane.width}" fitHeight="${rootPane.height}" preserveRatio="false">
        <image>
            <Image url="@select restaurant bg.png"/>
        </image>
    </ImageView>

    <!-- Decorative Box (glass effect) around the main card -->
    <StackPane maxWidth="680" maxHeight="680"
               style="-fx-background-color: white; -fx-background-radius: 36px; -fx-padding: 15px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 30, 0, 0, 15);">
        
        <VBox alignment="CENTER" spacing="30" styleClass="ts-card" maxWidth="650" maxHeight="650" VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <!-- Header Section -->
            <VBox alignment="CENTER" spacing="10">
                <Label text="Select Restaurant" styleClass="ts-page-title" style="-fx-font-size: 36px;"/>
                <Label fx:id="stationInfoLabel" styleClass="ts-page-subtitle" style="-fx-font-size: 18px;"/>
            </VBox>

            <Label text="Available Restaurants" styleClass="ts-section-header" style="-fx-font-size: 20px;"/>

            <ListView fx:id="restaurantListView" 
                      VBox.vgrow="ALWAYS" 
                      styleClass="sl-list-view"/>
            
            <!-- Action Buttons -->
            <HBox spacing="20" alignment="CENTER_RIGHT">
                <Button text="← Back" onAction="#handleBack" styleClass="ts-btn-secondary" prefWidth="130" prefHeight="50" style="-fx-font-size: 16px;"/>
                <Button text="Select Restaurant" onAction="#handleSelectRestaurant" styleClass="ts-btn-primary" prefHeight="50" prefWidth="200" style="-fx-font-size: 16px;"/>
            </HBox>
        </VBox>
    </StackPane>

</StackPane>
