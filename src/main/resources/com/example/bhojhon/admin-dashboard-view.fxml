<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.example.bhojhon.controller.AdminDashboardController"
    styleClass="admin-root">

    <!-- ═══════════════════════════════════════════ -->
    <!--  LEFT SIDEBAR                               -->
    <!-- ═══════════════════════════════════════════ -->
    <left>
        <VBox styleClass="sidebar" spacing="4.0" minWidth="220.0" maxWidth="220.0">
            <padding>
                <Insets top="28.0" bottom="24.0" left="16.0" right="16.0"/>
            </padding>

            <!-- Brand -->
            <VBox styleClass="sidebar-brand" spacing="3.0">
                <padding><Insets bottom="28.0"/></padding>
                <Label text="🚂 RailKhabar" styleClass="sidebar-brand-title"/>
                <Label text="Admin Console" styleClass="sidebar-brand-sub"/>
            </VBox>

            <!-- Nav: Dashboard -->
            <HBox styleClass="nav-item nav-item-active" alignment="CENTER_LEFT" spacing="12.0">
                <Label text="⊞" styleClass="nav-icon"/>
                <Label text="Dashboard" styleClass="nav-label"/>
            </HBox>

<!--            &lt;!&ndash; Nav: Restaurants &ndash;&gt;-->
<!--            <HBox styleClass="nav-item" alignment="CENTER_LEFT" spacing="12.0">-->
<!--                <Label text="🏪" styleClass="nav-icon"/>-->
<!--                <Label text="Restaurants" styleClass="nav-label"/>-->
<!--            </HBox>-->

<!--            &lt;!&ndash; Nav: Orders &ndash;&gt;-->
<!--            <HBox styleClass="nav-item" alignment="CENTER_LEFT" spacing="12.0">-->
<!--                <Label text="📋" styleClass="nav-icon"/>-->
<!--                <Label text="Orders" styleClass="nav-label"/>-->
<!--            </HBox>-->

<!--            &lt;!&ndash; Nav: Stations &ndash;&gt;-->
<!--            <HBox styleClass="nav-item" alignment="CENTER_LEFT" spacing="12.0">-->
<!--                <Label text="📍" styleClass="nav-icon"/>-->
<!--                <Label text="Stations" styleClass="nav-label"/>-->
<!--            </HBox>-->

            <!-- Spacer -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- Divider line -->
            <Region styleClass="sidebar-divider" maxHeight="1.0" minHeight="1.0"/>

            <!-- Logout -->
            <HBox styleClass="nav-item nav-item-logout" alignment="CENTER_LEFT" spacing="12.0"
                  onMouseClicked="#handleLogout" style="-fx-cursor: hand;">
                <Label text="⏻" styleClass="nav-icon"/>
                <Label text="Logout" styleClass="nav-label"/>
            </HBox>

        </VBox>
    </left>

    <!-- ═══════════════════════════════════════════ -->
    <!--  CENTER: Header + Content                   -->
    <!-- ═══════════════════════════════════════════ -->
    <center>
        <VBox styleClass="admin-content-area" spacing="0.0">

            <!-- ── TOP HEADER BAR ── -->
            <HBox styleClass="admin-header" alignment="CENTER_LEFT" spacing="16.0">
                <VBox spacing="2.0">
                    <Label text="Admin Dashboard" styleClass="admin-header-title"/>
                    <Label text="Overview of your platform data" styleClass="admin-header-sub"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="⟳  Refresh All" onAction="#loadData" styleClass="btn-refresh"/>
                <HBox styleClass="admin-avatar" alignment="CENTER" minWidth="36.0" minHeight="36.0">
                    <Label text="A" styleClass="admin-avatar-label"/>
                </HBox>
            </HBox>

            <!-- ── SCROLLABLE CONTENT ── -->
            <VBox VBox.vgrow="ALWAYS" styleClass="admin-scroll-area" spacing="24.0">
                <padding>
                    <Insets top="24.0" right="28.0" bottom="28.0" left="28.0"/>
                </padding>

                <!-- ─ STAT CARDS ROW ─ -->
                <HBox spacing="20.0" alignment="CENTER_LEFT">

                    <!-- Card 1: Restaurants -->
                    <VBox styleClass="stat-card stat-card-blue" spacing="8.0" HBox.hgrow="ALWAYS">
                        <padding><Insets top="22.0" right="22.0" bottom="22.0" left="22.0"/></padding>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <Label text="🏪" style="-fx-font-size: 26px;"/>
                            <VBox spacing="4.0">
                                <Label fx:id="statRestaurantsValue" text="0" styleClass="stat-value"/>
                                <Label text="Restaurants" styleClass="stat-label"/>
                            </VBox>
                        </HBox>
                        <Label text="Registered on platform" styleClass="stat-sub"/>
                    </VBox>

                    <!-- Card 2: Orders -->
                    <VBox styleClass="stat-card stat-card-green" spacing="8.0" HBox.hgrow="ALWAYS">
                        <padding><Insets top="22.0" right="22.0" bottom="22.0" left="22.0"/></padding>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <Label text="📦" style="-fx-font-size: 26px;"/>
                            <VBox spacing="4.0">
                                <Label fx:id="statOrdersValue" text="0" styleClass="stat-value"/>
                                <Label text="Orders" styleClass="stat-label"/>
                            </VBox>
                        </HBox>
                        <Label text="Total orders placed" styleClass="stat-sub"/>
                    </VBox>

                    <!-- Card 3: Stations -->
                    <VBox styleClass="stat-card stat-card-purple" spacing="8.0" HBox.hgrow="ALWAYS">
                        <padding><Insets top="22.0" right="22.0" bottom="22.0" left="22.0"/></padding>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <Label text="📍" style="-fx-font-size: 26px;"/>
                            <VBox spacing="4.0">
                                <Label fx:id="statStationsValue" text="0" styleClass="stat-value"/>
                                <Label text="Stations" styleClass="stat-label"/>
                            </VBox>
                        </HBox>
                        <Label text="Active railway stations" styleClass="stat-sub"/>
                    </VBox>

                </HBox>

                <!-- ─ SECTION TITLE ─ -->
                <VBox spacing="2.0">
                    <Label text="Data Management" styleClass="section-title-admin"/>
                    <Label text="View and manage platform records below" styleClass="section-sub-admin"/>
                </VBox>

                <!-- ─ TAB PANE ─ -->
                <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE" styleClass="admin-tab-pane">

                    <!-- Orders Tab -->
                    <Tab text="📋  All Orders">
                        <VBox spacing="0.0">
                            <padding><Insets top="16.0"/></padding>
                            <TableView fx:id="ordersTable" VBox.vgrow="ALWAYS"
                                       styleClass="admin-table" minHeight="300.0">
                                <columns>
                                    <TableColumn fx:id="orderIdCol"  text="Order ID"       prefWidth="110.0"/>
                                    <TableColumn fx:id="nameCol"     text="Passenger"      prefWidth="140.0"/>
                                    <TableColumn fx:id="phoneCol"    text="Phone"          prefWidth="120.0"/>
                                    <TableColumn fx:id="trainCol"    text="Train"          prefWidth="80.0"/>
                                    <TableColumn fx:id="seatCol"     text="Seat"           prefWidth="70.0"/>
                                    <TableColumn fx:id="stationCol"  text="Station"        prefWidth="120.0"/>
                                    <TableColumn fx:id="itemsCol"    text="Items Ordered"  prefWidth="220.0"/>
                                    <TableColumn fx:id="totalCol"    text="Total (৳)"     prefWidth="95.0"/>
                                    <TableColumn fx:id="dateCol"     text="Order Date"     prefWidth="145.0"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </Tab>

                    <!-- Restaurants Tab -->
                    <Tab text="🏪  Registered Restaurants">
                        <VBox spacing="14.0">
                            <padding><Insets top="16.0"/></padding>

                            <!-- Mini stat + refresh row -->
                            <HBox alignment="CENTER_LEFT" spacing="12.0">
                                <Label fx:id="totalRestaurantsLabel"
                                       text="Total Registered Restaurants: 0"
                                       styleClass="restaurant-count-badge"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="⟳  Refresh" onAction="#loadRestaurants"
                                        styleClass="btn-refresh-green"/>
                            </HBox>

                            <!-- Restaurant table -->
                            <TableView fx:id="restaurantsTable" VBox.vgrow="ALWAYS"
                                       styleClass="admin-table" minHeight="280.0">
                                <columns>
                                    <TableColumn fx:id="restaurantNameCol"    text="Restaurant Name"  prefWidth="210.0"/>
                                    <TableColumn fx:id="ownerEmailCol"        text="Owner Email"      prefWidth="230.0"/>
                                    <TableColumn fx:id="restaurantStationCol" text="Station"          prefWidth="190.0"/>
                                    <TableColumn fx:id="regDateCol"           text="Registered On"    prefWidth="220.0"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </Tab>

                </TabPane>
            </VBox>
            <!-- end scroll area -->

        </VBox>
    </center>

</BorderPane>