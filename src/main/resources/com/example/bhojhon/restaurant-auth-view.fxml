<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.bhojhon.controller.RestaurantAuthController"
           styleClass="login-root"
           stylesheets="@styles.css">

    <!-- Decorative background elements -->
    <AnchorPane>
        <Region AnchorPane.rightAnchor="0" AnchorPane.topAnchor="150" prefWidth="120" prefHeight="48" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 24 0 0 24;" />
        <Region AnchorPane.leftAnchor="0" AnchorPane.topAnchor="450" prefWidth="180" prefHeight="64" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 0 32 32 0;" />
        <Region AnchorPane.leftAnchor="200" AnchorPane.bottomAnchor="0" prefWidth="80" prefHeight="140" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 12 12 0 0;" />
    </AnchorPane>

    <!-- Main Content -->
    <VBox alignment="CENTER" spacing="20">
        <!-- Header -->
        <VBox alignment="CENTER" spacing="-5">
            <Label text="Partner Portal" styleClass="menu-main-title" style="-fx-font-size: 36px;"/>
            <Label text="RESTAURANT MANAGEMENT" styleClass="menu-sub-title" style="-fx-font-size: 14px; -fx-letter-spacing: 2px;"/>
        </VBox>

        <!-- Auth Card -->
        <VBox styleClass="login-card-container" maxWidth="450" alignment="TOP_CENTER" spacing="0">
            
            <Label text="Welcome Partner" styleClass="login-title"/>
            <Label text="Login or create an account to continue" styleClass="login-subtitle">
                <VBox.margin><Insets top="5"/></VBox.margin>
            </Label>

            <!-- Toggle (Login / Register) -->
            <HBox styleClass="login-toggle-container">
                <VBox.margin><Insets top="20" bottom="20"/></VBox.margin>
                <Button fx:id="loginToggleBtn" text="Login" onAction="#switchToLogin" 
                        styleClass="login-toggle-btn login-toggle-active" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button fx:id="registerToggleBtn" text="Register" onAction="#switchToRegister" 
                        styleClass="login-toggle-btn" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            </HBox>

            <!-- Forms Area -->
            <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" styleClass="ra-tab-pane">
                <tabs>
                    <!-- Login Tab -->
                    <Tab>
                        <VBox spacing="18" alignment="CENTER_LEFT">
                            <VBox.margin><Insets top="10"/></VBox.margin>
                            <VBox spacing="8">
                                <Label text="Email Address" styleClass="login-field-label"/>
                                <TextField fx:id="loginEmailField" promptText="owner@restaurant.com" styleClass="login-field"/>
                            </VBox>
                            <VBox spacing="8">
                                <Label text="Password" styleClass="login-field-label"/>
                                <PasswordField fx:id="loginPasswordField" promptText="Enter your password" styleClass="login-field"/>
                            </VBox>
                            
                            <Label fx:id="loginErrorLabel" styleClass="login-error-label" visible="false"/>
                            
                            <Button text="Sign In" onAction="#handleLogin" maxWidth="Infinity" styleClass="login-btn-primary">
                                <VBox.margin><Insets top="10"/></VBox.margin>
                            </Button>
                        </VBox>
                    </Tab>
                    
                    <!-- Register Tab -->
                    <Tab>
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;" hbarPolicy="NEVER">
                            <VBox spacing="15" alignment="CENTER_LEFT">
                                <padding><Insets right="5" top="10"/></padding>
                                <VBox spacing="5">
                                    <Label text="Restaurant Name" styleClass="login-field-label"/>
                                    <TextField fx:id="registerRestaurantNameField" promptText="Enter restaurant name" styleClass="login-field"/>
                                </VBox>
                                <VBox spacing="5">
                                    <Label text="Email Address" styleClass="login-field-label"/>
                                    <TextField fx:id="registerEmailField" promptText="owner@restaurant.com" styleClass="login-field"/>
                                </VBox>
                                <VBox spacing="5">
                                    <Label text="Password" styleClass="login-field-label"/>
                                    <PasswordField fx:id="registerPasswordField" promptText="Create password" styleClass="login-field"/>
                                </VBox>
                                <VBox spacing="5">
                                    <Label text="Confirm Password" styleClass="login-field-label"/>
                                    <PasswordField fx:id="registerConfirmPasswordField" promptText="Confirm password" styleClass="login-field"/>
                                </VBox>
                                <VBox spacing="5">
                                    <Label text="Select Station" styleClass="login-field-label"/>
                                    <ComboBox fx:id="stationComboBox" promptText="Choose station" maxWidth="Infinity" styleClass="login-field"/>
                                </VBox>

                                <Label fx:id="registerErrorLabel" styleClass="login-error-label" visible="false"/>
                                
                                <Button text="Create Account" onAction="#handleRegister" maxWidth="Infinity" styleClass="login-btn-primary">
                                    <VBox.margin><Insets top="10"/></VBox.margin>
                                </Button>
                            </VBox>
                        </ScrollPane>
                    </Tab>
                </tabs>
            </TabPane>

            <!-- Action Buttons -->
            <HBox alignment="CENTER">
                <VBox.margin><Insets top="20"/></VBox.margin>
                <Button text="← Back to Main Menu" onAction="#handleBack" styleClass="login-btn-secondary"/>
            </HBox>

        </VBox>
    </VBox>

</StackPane>